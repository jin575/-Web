#!/bin/sh
# ================================================================
# 埋め込みGitリポジトリ（gitlink / mode 160000）の誤コミットを防ぐ
# ----------------------------------------------------------------
# 目的：新しいテンプレサイト等の「独立リポジトリのフォルダ」を、
#       親リポジトリ（自社サイト = 医療のみちしるべ）に誤って
#       コミットしてしまう事故を根絶する。
#
# 独立リポジトリは テンプレサイト/ 配下（.gitignore対象）に置くこと。
# ================================================================

# ステージ済みの変更のうち、追加先モードが 160000（gitlink）のものを検出
gitlinks=$(git diff --cached --raw | awk '$2 == "160000" { print $NF }')

if [ -n "$gitlinks" ]; then
	echo "❌ コミット中止：埋め込みGitリポジトリを親リポジトリに追加しようとしています。"
	echo ""
	echo "$gitlinks" | sed 's/^/   - /'
	echo ""
	echo "→ テンプレなど独立したGitHubリポジトリは テンプレサイト/ 配下に置いてください。"
	echo "  （テンプレサイト/ は .gitignore 済みなので自動的に無視されます）"
	echo ""
	echo "  誤ってステージした場合は次で取り消せます："
	echo "    git rm --cached <パス>"
	exit 1
fi

exit 0
